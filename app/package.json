{
  "name": "sparta-app-v2",
  "version": "1.2.0",
  "description": "Blank Node.js app scaffold",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node --test",
    "test:integration": "node -e \"process.env.RUN_MONGO_INTEGRATION='true'; const result=require('node:child_process').spawnSync(process.execPath,['--test','--test-name-pattern','\\\\[integration\\\\]'],{stdio:'inherit',env:process.env}); process.exit(result.status ?? 1);\"",
    "test:all": "node -e \"process.env.RUN_MONGO_INTEGRATION='true'; const result=require('node:child_process').spawnSync(process.execPath,['--test'],{stdio:'inherit',env:process.env}); process.exit(result.status ?? 1);\"",
    "postinstall": "node seeds/seed.js"
  },
  "dependencies": {
    "mongodb": "^6.12.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3"
  },
  "author": "",
  "license": "ISC"
}
